





import pandas as pd

pd.set_option('display.max_columns', None)





produtos = pd.read_csv('../../datasets/produtos_raw.csv')

produtos.sample(10)


produtos.info()








produtos.rename(
    columns={
        'code': 'id',
        'actual_category': 'category'
    },
    inplace=True
)

produtos.info()





print(produtos.duplicated().sum())


print(produtos.duplicated(subset='id').sum())


print(produtos.duplicated(subset='name').sum())


print(produtos.duplicated(subset='price').sum())


produtos[produtos.duplicated(subset='price', keep=False)]





produtos.drop_duplicates(
    subset='id',
    inplace=True
)

produtos.reset_index(
    drop=True,
    inplace=True
)

produtos.info()








def fix_category(string: str) -> str:
    s = string.lower()
    if s.startswith('e'):
        return 'eletrônicos'
    if s.startswith('p'):
        return 'propulsão'
    if s.startswith('a'):
        return 'ancoragem'
    return ''



produtos['price'] = produtos['price'].apply(lambda x: x[3:]).astype('float')

produtos['category'] = produtos['category'].apply(fix_category)

produtos.info()








categories = pd.DataFrame(
    {
    'id': [1, 2, 3],
    'name': ['eletrônicos', 'propulsão', 'ancoragem']
    }
)

produtos = (
    produtos.
        merge(
            categories,
            left_on='category',
            right_on='name'
        ).drop(
            columns=['name_y', 'category']
        ).rename(
            columns={
                'name_x': 'name',
                'id_x': 'id',
                'id_y': 'category_id'
            }
        )
)


produtos.head()


categories.head()
